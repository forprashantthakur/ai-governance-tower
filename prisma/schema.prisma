// ============================================================
// AI Governance Control Tower — Prisma Schema
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  RISK_OFFICER
  AUDITOR
  VIEWER
}

enum ModelType {
  LLM
  ML
  AGENT
  COMPUTER_VISION
  NLP
  RECOMMENDATION
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ModelStatus {
  ACTIVE
  INACTIVE
  DEPRECATED
  UNDER_REVIEW
  SUSPENDED
}

enum ComplianceStatus {
  PASS
  FAIL
  PARTIAL
  NOT_APPLICABLE
  PENDING_REVIEW
}

enum DataSensitivity {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
  PII
}

enum AgentStatus {
  RUNNING
  IDLE
  SUSPENDED
  ERROR
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  APPROVE
  REJECT
  ESCALATE
}

enum ConsentType {
  DATA_PROCESSING
  AI_DECISION
  DATA_SHARING
  MARKETING
}

enum ConsentStatus {
  GRANTED
  REVOKED
  PENDING
  EXPIRED
}

// ─── Core Identity ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         UserRole @default(VIEWER)
  department   String?
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  ownedModels       AIModel[]         @relation("ModelOwner")
  approvedModels    AIModel[]         @relation("ModelApprover")
  riskAssessments   RiskAssessment[]
  auditLogs         AuditLog[]
  apiKeys           ApiKey[]
  promptLogs        PromptLog[]
  ownedProjects     Project[]         @relation("ProjectOwner")
  taskAssignments   ProjectTask[]     @relation("TaskAssignee")
  taskReports       ProjectTask[]     @relation("TaskReporter")
  projectResources  ProjectResource[] @relation("ProjectResources")

  @@map("users")
}

model ApiKey {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  keyHash     String   @unique @map("key_hash")
  keyPrefix   String   @map("key_prefix")
  permissions String[] @default([])
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ─── AI Model Registry ────────────────────────────────────────────────────────

model AIModel {
  id               String       @id @default(uuid())
  name             String
  version          String       @default("1.0.0")
  description      String?
  type             ModelType
  status           ModelStatus  @default(ACTIVE)
  ownerId          String       @map("owner_id")
  approverId       String?      @map("approver_id")
  department       String?
  vendor           String?
  framework        String?      // e.g. PyTorch, TensorFlow, OpenAI
  endpoint         String?      // API endpoint if applicable
  tags             String[]     @default([])
  metadata         Json?        // flexible extra fields
  isPiiProcessing  Boolean      @default(false) @map("is_pii_processing")
  isFinancial      Boolean      @default(false) @map("is_financial")
  isCritical       Boolean      @default(false) @map("is_critical")
  humanOversight   Boolean      @default(true)  @map("human_oversight")
  explainability   Int          @default(50)    // 0-100 score
  trainingDataset  String?      @map("training_dataset")  // name of training dataset
  accuracyScore    Float?       @map("accuracy_score")    // 0.0-1.0 (e.g. 0.95 = 95%)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  owner              User               @relation("ModelOwner", fields: [ownerId], references: [id])
  approver           User?              @relation("ModelApprover", fields: [approverId], references: [id])
  riskAssessments    RiskAssessment[]
  complianceControls ComplianceControl[]
  dataAssets         ModelDataAsset[]
  agents             Agent[]
  promptLogs         PromptLog[]
  auditLogs          AuditLog[]
  projectLinks       ProjectAIModel[]
  evidenceFiles      EvidenceFile[]
  impactAssessment   ImpactAssessment?
  interestedParties  InterestedParty[]

  @@map("ai_models")
}

// ─── Risk & Compliance ────────────────────────────────────────────────────────

model RiskAssessment {
  id                  String    @id @default(uuid())
  modelId             String    @map("model_id")
  assessorId          String    @map("assessor_id")
  riskLevel           RiskLevel
  overallScore        Float     @map("overall_score")      // 0-100

  // Score dimensions
  dataSensitivityScore    Float @default(0) @map("data_sensitivity_score")
  modelComplexityScore    Float @default(0) @map("model_complexity_score")
  explainabilityScore     Float @default(0) @map("explainability_score")
  humanOversightScore     Float @default(0) @map("human_oversight_score")
  regulatoryExposureScore Float @default(0) @map("regulatory_exposure_score")

  findings        String?
  mitigations     String?
  reviewedAt      DateTime? @map("reviewed_at")
  nextReviewDate  DateTime? @map("next_review_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  model         AIModel        @relation(fields: [modelId], references: [id], onDelete: Cascade)
  assessor      User           @relation(fields: [assessorId], references: [id])
  evidenceFiles EvidenceFile[]

  @@map("risk_assessments")
}

model ComplianceControl {
  id           String           @id @default(uuid())
  modelId      String           @map("model_id")
  framework    String           // e.g. "DPDP", "ISO42001", "ISO42005"
  controlId    String           @map("control_id")   // e.g. "DPDP-7.2"
  controlName  String           @map("control_name")
  description  String?
  status       ComplianceStatus @default(PENDING_REVIEW)
  evidence     String?
  notes        String?
  reviewedAt   DateTime?        @map("reviewed_at")
  reviewedBy   String?          @map("reviewed_by")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  model         AIModel        @relation(fields: [modelId], references: [id], onDelete: Cascade)
  evidenceFiles EvidenceFile[]

  @@unique([modelId, framework, controlId])
  @@map("compliance_controls")
}

// ─── Data Governance ─────────────────────────────────────────────────────────

model DataAsset {
  id               String          @id @default(uuid())
  name             String
  description      String?
  source           String          // e.g. "CRM", "S3 bucket", "API"
  dataType         String          @map("data_type")  // e.g. "structured", "unstructured"
  sensitivity      DataSensitivity
  hasPii           Boolean         @default(false) @map("has_pii")
  piiFields        String[]        @default([]) @map("pii_fields")
  retentionDays    Int?            @map("retention_days")
  location         String?         // storage location / path
  format           String?         // CSV, JSON, Parquet, etc.
  owner            String?
  tags             String[]        @default([])
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  models         ModelDataAsset[]
  consentRecords ConsentRecord[]
  evidenceFiles  EvidenceFile[]

  @@map("data_assets")
}

model ModelDataAsset {
  modelId     String   @map("model_id")
  dataAssetId String   @map("data_asset_id")
  role        String   @default("input") // input | output | training
  createdAt   DateTime @default(now()) @map("created_at")

  model     AIModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  dataAsset DataAsset @relation(fields: [dataAssetId], references: [id], onDelete: Cascade)

  @@id([modelId, dataAssetId])
  @@map("model_data_assets")
}

model ConsentRecord {
  id           String        @id @default(uuid())
  dataAssetId  String        @map("data_asset_id")
  subjectId    String        @map("subject_id")    // data subject identifier
  consentType  ConsentType   @map("consent_type")
  status       ConsentStatus
  grantedAt    DateTime?     @map("granted_at")
  revokedAt    DateTime?     @map("revoked_at")
  expiresAt    DateTime?     @map("expires_at")
  ipAddress    String?       @map("ip_address")
  metadata     Json?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  dataAsset DataAsset @relation(fields: [dataAssetId], references: [id], onDelete: Cascade)

  @@map("consent_records")
}

// ─── Agent Governance ────────────────────────────────────────────────────────

model Agent {
  id           String      @id @default(uuid())
  name         String
  description  String?
  modelId      String      @map("model_id")
  status       AgentStatus @default(IDLE)
  systemPrompt String?     @map("system_prompt")
  tools        String[]    @default([])  // tool names the agent can use
  version      String      @default("1.0.0")
  maxTokens    Int?        @map("max_tokens")
  temperature  Float?
  metadata     Json?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  model      AIModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  promptLogs PromptLog[]

  @@map("agents")
}

model PromptLog {
  id               String   @id @default(uuid())
  agentId          String?  @map("agent_id")
  modelId          String   @map("model_id")
  userId           String?  @map("user_id")
  sessionId        String?  @map("session_id")

  // Request
  prompt           String
  systemPrompt     String?  @map("system_prompt")
  toolsUsed        String[] @default([]) @map("tools_used")

  // Response
  response         String?
  inputTokens      Int?     @map("input_tokens")
  outputTokens     Int?     @map("output_tokens")
  latencyMs        Int?     @map("latency_ms")

  // Quality flags
  isHallucination  Boolean  @default(false) @map("is_hallucination")
  isPolicyViolation Boolean @default(false) @map("is_policy_violation")
  toxicityScore    Float?   @map("toxicity_score")   // 0-1
  accuracyScore    Float?   @map("accuracy_score")   // 0-1 (manual)
  biasScore        Float?   @map("bias_score")        // 0-1
  flagged          Boolean  @default(false)
  flagReason       String?  @map("flag_reason")

  // Metadata
  environment      String   @default("production")
  ipAddress        String?  @map("ip_address")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")

  agent  Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)
  model  AIModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([modelId, createdAt])
  @@index([agentId, createdAt])
  @@index([flagged])
  @@map("prompt_logs")
}

// ─── Monitoring & Alerts ─────────────────────────────────────────────────────

model Alert {
  id         String        @id @default(uuid())
  title      String
  message    String
  severity   AlertSeverity
  modelId    String?       @map("model_id")
  agentId    String?       @map("agent_id")
  isRead     Boolean       @default(false) @map("is_read")
  resolvedAt DateTime?     @map("resolved_at")
  resolvedBy String?       @map("resolved_by")
  metadata   Json?
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([isRead, severity])
  @@map("alerts")
}

// ─── Audit Trail ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?     @map("user_id")
  action     AuditAction
  resource   String      // e.g. "AIModel", "RiskAssessment"
  resourceId String?     @map("resource_id")
  modelId    String?     @map("model_id")
  before     Json?       // previous state snapshot
  after      Json?       // new state snapshot
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  user  User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  model AIModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── AI Project Management — Enums ───────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPhase {
  BUSINESS_CASE
  DATA_DISCOVERY
  MODEL_DEVELOPMENT
  TESTING_VALIDATION
  DEPLOYMENT
  MONITORING
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ResourceRole {
  LEAD
  CONTRIBUTOR
  REVIEWER
  STAKEHOLDER
  OBSERVER
}

enum WorkflowNodeType {
  DATA_SOURCE
  TRANSFORM
  MODEL
  EVALUATION
  OUTPUT
  DECISION
  TRIGGER
  NOTIFICATION
}

enum N8nTriggerEvent {
  PHASE_COMPLETE
  MILESTONE_REACHED
  TASK_DONE
  RISK_THRESHOLD
  EXPERIMENT_LOGGED
}

enum ProjectHealthStatus {
  HEALTHY
  AT_RISK
  CRITICAL
  UNKNOWN
}

// ─── AI Project Management — Models ──────────────────────────────────────────

model ProjectTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String
  scaffold    Json
  isBuiltIn   Boolean  @default(false) @map("is_built_in")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("project_templates")
}

model Project {
  id           String              @id @default(uuid())
  name         String
  description  String?
  status       ProjectStatus       @default(DRAFT)
  currentPhase ProjectPhase        @default(BUSINESS_CASE) @map("current_phase")
  ownerId      String              @map("owner_id")
  templateId   String?             @map("template_id")
  startDate    DateTime?           @map("start_date")
  targetDate   DateTime?           @map("target_date")
  completedAt  DateTime?           @map("completed_at")
  healthScore  Float               @default(100) @map("health_score")
  healthStatus ProjectHealthStatus @default(UNKNOWN) @map("health_status")
  budget       Float?
  tags         String[]            @default([])
  metadata     Json?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  owner        User                 @relation("ProjectOwner", fields: [ownerId], references: [id])
  template     ProjectTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  phases       ProjectPhaseRecord[]
  tasks        ProjectTask[]
  milestones   Milestone[]
  resources    ProjectResource[]
  experiments  Experiment[]
  workflows    WorkflowCanvas[]
  n8nWebhooks  N8nWebhook[]
  linkedModels ProjectAIModel[]

  @@index([status, healthStatus])
  @@index([ownerId])
  @@map("projects")
}

model ProjectPhaseRecord {
  id          String       @id @default(uuid())
  projectId   String       @map("project_id")
  phase       ProjectPhase
  status      TaskStatus   @default(BACKLOG)
  startDate   DateTime?    @map("start_date")
  endDate     DateTime?    @map("end_date")
  plannedDays Int?         @map("planned_days")
  actualDays  Int?         @map("actual_days")
  progress    Int          @default(0)
  notes       String?
  completedAt DateTime?    @map("completed_at")
  completedBy String?      @map("completed_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, phase])
  @@map("project_phase_records")
}

model ProjectTask {
  id           String       @id @default(uuid())
  projectId    String       @map("project_id")
  phase        ProjectPhase
  title        String
  description  String?
  status       TaskStatus   @default(BACKLOG)
  priority     TaskPriority @default(MEDIUM)
  assigneeId   String?      @map("assignee_id")
  reporterId   String?      @map("reporter_id")
  dueDate      DateTime?    @map("due_date")
  startDate    DateTime?    @map("start_date")
  estimatedHrs Float?       @map("estimated_hrs")
  actualHrs    Float?       @map("actual_hrs")
  sortOrder    Int          @default(0) @map("sort_order")
  parentTaskId String?      @map("parent_task_id")
  tags         String[]     @default([])
  completedAt  DateTime?    @map("completed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter   User?        @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  parentTask ProjectTask?  @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks   ProjectTask[] @relation("TaskSubtasks")

  @@index([projectId, phase, status])
  @@index([assigneeId])
  @@map("project_tasks")
}

model Milestone {
  id          String       @id @default(uuid())
  projectId   String       @map("project_id")
  phase       ProjectPhase
  name        String
  description String?
  targetDate  DateTime     @map("target_date")
  completedAt DateTime?    @map("completed_at")
  completedBy String?      @map("completed_by")
  isGate      Boolean      @default(false) @map("is_gate")
  createdAt   DateTime     @default(now()) @map("created_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  n8nTriggers N8nWebhook[] @relation("MilestoneTrigger")

  @@index([projectId])
  @@map("milestones")
}

model ProjectResource {
  id            String       @id @default(uuid())
  projectId     String       @map("project_id")
  userId        String       @map("user_id")
  role          ResourceRole @default(CONTRIBUTOR)
  allocationPct Int          @default(50) @map("allocation_pct")
  startDate     DateTime?    @map("start_date")
  endDate       DateTime?    @map("end_date")
  hourlyRate    Float?       @map("hourly_rate")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectResources", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_resources")
}

model Experiment {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String
  description String?
  status      String    @default("running")
  runId       String?   @map("run_id")
  hyperparams Json?
  metrics     Json?
  artifacts   Json?
  datasetRef  String?   @map("dataset_ref")
  modelRef    String?   @map("model_ref")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdBy   String    @map("created_by")
  notes       String?
  tags        String[]  @default([])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    ExperimentRun[]

  @@index([projectId, status])
  @@map("experiments")
}

model ExperimentRun {
  id           String   @id @default(uuid())
  experimentId String   @map("experiment_id")
  runNumber    Int      @map("run_number")
  hyperparams  Json?
  metrics      Json?
  artifacts    Json?
  status       String   @default("running")
  duration     Int?
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@unique([experimentId, runNumber])
  @@map("experiment_runs")
}

model WorkflowCanvas {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  canvasData  Json     @map("canvas_data")
  version     Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("workflow_canvases")
}

model N8nWebhook {
  id              String         @id @default(uuid())
  projectId       String         @map("project_id")
  name            String
  webhookUrl      String         @map("webhook_url")
  triggerEvent    N8nTriggerEvent @map("trigger_event")
  milestoneId     String?        @map("milestone_id")
  isActive        Boolean        @default(true) @map("is_active")
  payloadTemplate Json?          @map("payload_template")
  lastTriggeredAt DateTime?      @map("last_triggered_at")
  lastStatus      String?        @map("last_status")
  lastResponse    Json?          @map("last_response")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation("MilestoneTrigger", fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("n8n_webhooks")
}

model ProjectAIModel {
  projectId String @map("project_id")
  modelId   String @map("model_id")
  role      String @default("output")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  model   AIModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@id([projectId, modelId])
  @@map("project_ai_models")
}

// ─── Policy Configuration ─────────────────────────────────────────────────────

model PolicyConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("policy_configs")
}

// ─── ISO 42005 Evidence & Compliance ────────────────────────────────────────

/// Uploaded evidence files — attached to compliance controls, risk assessments, models, or data assets
model EvidenceFile {
  id           String   @id @default(uuid())
  name         String
  url          String
  size         Int
  mimeType     String   @map("mime_type")
  uploadedBy   String   @map("uploaded_by")   // userId
  section      String?  // ISO clause reference, e.g. "5.3.4"
  description  String?
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  // Polymorphic parent references (at most one is non-null)
  controlId    String?  @map("control_id")
  riskId       String?  @map("risk_id")
  modelId      String?  @map("model_id")
  dataAssetId  String?  @map("data_asset_id")

  control   ComplianceControl? @relation(fields: [controlId],   references: [id], onDelete: Cascade)
  risk      RiskAssessment?    @relation(fields: [riskId],      references: [id], onDelete: Cascade)
  model     AIModel?           @relation(fields: [modelId],     references: [id], onDelete: Cascade)
  dataAsset DataAsset?         @relation(fields: [dataAssetId], references: [id], onDelete: Cascade)

  @@index([controlId])
  @@index([modelId])
  @@map("evidence_files")
}

/// ISO 42005 §5.3–§5.8 — full impact assessment record per AI model
/// §5.3 intended/unintended uses, §5.5 algorithm info, §5.6 deployment env,
/// §5.8 nine impact dimensions — stored here to avoid altering ai_models table
model ImpactAssessment {
  id      String  @id @default(uuid())
  modelId String  @unique @map("model_id")

  // ── §5.3 AI System Information ─────────────────────────────────────
  intendedUses         String[]  @default([]) @map("intended_uses")
  unintendedUses       String[]  @default([]) @map("unintended_uses")

  // ── §5.5 Algorithm & Model ──────────────────────────────────────────
  algorithmType        String?   @map("algorithm_type")
  algorithmDescription String?   @map("algorithm_description")
  developmentApproach  String?   @map("development_approach")

  // ── §5.6 Deployment Environment ─────────────────────────────────────
  geographicScope        String[]  @default([]) @map("geographic_scope")
  deploymentLanguages    String[]  @default([]) @map("deployment_languages")
  environmentDescription String?   @map("environment_description")

  // ── §5.8 Impact Dimensions ──────────────────────────────────────────
  // §5.8.2.2 Accountability
  accountability      String?
  // §5.8.2.3 Transparency
  transparency        String?
  // §5.8.2.4 Fairness & Non-discrimination
  fairness            String?
  // §5.8.2.5 Privacy
  privacy             String?
  // §5.8.2.6 Reliability & Robustness
  reliability         String?
  // §5.8.2.7 Safety
  safety              String?
  // §5.8.2.8 Explainability
  explainabilityDoc   String?  @map("explainability_doc")
  // §5.8.2.9 Environmental Impact
  environmentalImpact String?  @map("environmental_impact")
  // §5.8.3 Failures & Misuse
  failureMisuse       String?  @map("failure_misuse")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  model AIModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@map("impact_assessments")
}

enum InterestedPartyRole {
  USER
  DATA_SUBJECT
  DEPLOYER
  DEVELOPER
  REGULATOR
  SUPPLIER
  OTHER
}

/// ISO 42005 §5.7 — interested party register per AI model
model InterestedParty {
  id          String              @id @default(uuid())
  modelId     String              @map("model_id")
  name        String
  role        InterestedPartyRole @default(OTHER)
  interest    String?             // their interest/concern regarding the AI system
  consulted   Boolean             @default(false)
  consultedAt DateTime?           @map("consulted_at")
  notes       String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  model AIModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("interested_parties")
}
