# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_governance?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here"
JWT_EXPIRES_IN="24h"
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── OpenAI / Azure OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
# Uncomment for Azure OpenAI
# AZURE_OPENAI_API_KEY="..."
# AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
# AZURE_OPENAI_API_VERSION="2024-02-01"
# AZURE_OPENAI_DEPLOYMENT="gpt-4o"

# ─── Langfuse Observability ───────────────────────────────────────────────────
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_HOST="https://cloud.langfuse.com"

# ─── Pinecone (optional vector DB) ───────────────────────────────────────────
# PINECONE_API_KEY="..."
# PINECONE_INDEX="ai-governance"
# PINECONE_ENVIRONMENT="gcp-starter"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AI Governance Control Tower"
NODE_ENV="development"
